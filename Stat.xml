<?xml version="1.0" encoding="utf-8"?>
<Languages>

<!--Spells-->
<Key Id="sta_spel_czarls_one_nazwa">Bombardeio</Key>
<Key Id="sta_spel_czarls_one_opis">Projéteis caindo do céu na área selecionada.</Key>	

<Key Id="sta_spel_czarls_two_nazwa">Projétil gigante</Key>
<Key Id="sta_spel_czarls_otwo_opis">Um enorme projétil de energia que lança projéteis menores.</Key>	
	
<Key Id="sta_spel_czarls_pasyw_nazwa">Ataque adicional</Key>
<Key Id="sta_spel_czarls_pasyw_opis">Ao acertar um inimigo, você tem chance de disparar um projétil adicional.</Key>		
	
<Key Id="sta_spel_dziadek_one_nazwa">Nevasca</Key>
<Key Id="sta_spel_dziadek_one_opis">Uma tempestade de neve aparece e desacelera seus inimigos.</Key>	

<Key Id="sta_spel_dziadek_two_nazwa">Blocos de gelo</Key>
<Key Id="sta_spel_dziadek_otwo_opis">Blocos de gelo caem sobre inimigos próximos.</Key>	
	
<Key Id="sta_spel_dziadek_pasyw_nazwa">Controle de projéteis</Key>
<Key Id="sta_spel_dziadek_pasyw_opis">Você pode desacelerar projéteis inimigos. Alguns dos seus projéteis também podem atravessar inimigos.</Key>

<Key Id="sta_spel_druid_one_nazwa">Detonador de cogumelos</Key>
<Key Id="sta_spel_druid_one_opis">Você detona todos os cogumelos ao redor.</Key>	

<Key Id="sta_spel_druid_two_nazwa">Praga de cogumelos</Key>
<Key Id="sta_spel_druid_otwo_opis">Uma horda de cogumelos mutantes aparece para atacar inimigos e espalhar pequenos cogumelos explosivos.</Key>	
	
<Key Id="sta_spel_druid_pasyw_nazwa">A praga</Key>
<Key Id="sta_spel_druid_pasyw_opis">Inimigos infectados por cogumelos recebem mais dano.</Key>
	
<Key Id="sta_spel_nieumarlak_one_nazwa">Nuvem tóxica</Key>
<Key Id="sta_spel_nieumarlak_one_opis">Uma nuvem de toxinas aparece para causar dano aos inimigos.</Key>	

<Key Id="sta_spel_nieumarlak_two_nazwa">Doença fedorenta</Key>
<Key Id="sta_spel_nieumarlak_otwo_opis">Você gera contaminantes tóxicos.</Key>	
	
<Key Id="sta_spel_nieumarlak_pasyw_nazwa">Túmulo de pedra</Key>
<Key Id="sta_spel_nieumarlak_pasyw_opis">Ao atacar inimigos, você tem chance de acertá-los com uma lápide pesada.</Key>

<Key Id="sta_spel_priest_one_nazwa">Estátua de poder</Key>
<Key Id="sta_spel_priest_one_opis">Atrai inimigos e causa dano.</Key>	

<Key Id="sta_spel_priest_two_nazwa">Punho da conversão</Key>
<Key Id="sta_spel_priest_otwo_opis">Um punho poderoso cai do céu para causar dano aos inimigos.</Key>	
	
<Key Id="sta_spel_priest_pasyw_nazwa">Maldição</Key>
<Key Id="sta_spel_priest_pasyw_opis">Seus ataques podem amaldiçoar inimigos. Inimigos amaldiçoados recebem mais dano.</Key>

<Key Id="sta_spel_nekromanta_one_nazwa">Invocar esqueletos</Key>
<Key Id="sta_spel_nekromanta_one_opis">Você invoca esqueletos para atacar seus inimigos.</Key>	

<Key Id="sta_spel_nekromanta_two_nazwa">Golem</Key>
<Key Id="sta_spel_nekromanta_otwo_opis">Você invoca um poderoso golem para lutar ao seu lado.</Key>	
	
<Key Id="sta_spel_nekromanta_pasyw_nazwa">Vermes</Key>
<Key Id="sta_spel_nekromanta_pasyw_opis">Vermes rastejantes saem dos inimigos mortos.</Key>

